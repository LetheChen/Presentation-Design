#!/usr/bin/env bash
# .openclaw-install
# OpenClaw skill 安装后自动执行此脚本（位于 skill 根目录）
# 用途：自动安装 npm 依赖 + Playwright 浏览器

set -e

SKILL_DIR="$(cd "$(dirname "$0")" && pwd)"
echo "[Presentation Design] 安装依赖中..."

# 切换到 skill 目录
cd "$SKILL_DIR"

# 安装 Node.js 依赖
npm install --silent 2>/dev/null || npm install

# 安装 Playwright 浏览器
npx playwright install chromium --with-deps 2>/dev/null || npx playwright install chromium

echo "[Presentation Design] 依赖安装完成 ✅"
